{
  "$schema": "https://json.schemastore.org/package",
  "name": "goal",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "format:check": "prettier . --check --ignore-unknown",
    "format": "prettier . --write --ignore-unknown",
    "lint:fix": "bunx eslint . --fix",
    "lint": "bunx eslint .",
    "test:apps": "bun test ./apps --jsx-import-source hono/jsx",
    "typecheck": "bunx tsc -b --noEmit"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.11",
    "@tsconfig/bun": "^1.0.10",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "version": "1.0.0"
}
