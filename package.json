{
  "$schema": "https://json.schemastore.org/package",
  "name": "goal",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "test:apps": "bun test ./apps --jsx-import-source hono/jsx",
    "typecheck": "bunx tsc -b --noEmit"
  },
  "private": true,
  "devDependencies": {
    "@tsconfig/bun": "^1.0.10",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2"
  },
  "version": "1.0.0"
}
